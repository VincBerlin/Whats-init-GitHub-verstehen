# ── What's in it? — Environment variables ───────────────────────────

# LLM provider (PHASE-3): OpenRouter, server-side only. Gemini behind OpenRouter.
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Legacy direct-Gemini path (PHASE-2 bridge only; removed once OpenRouter is live).
GEMINI_API_KEY=your_gemini_api_key

# GitHub API (optional but recommended: raises rate limit 60 → 5000 req/h).
GITHUB_TOKEN=your_github_personal_access_token

# Database (PHASE-2): Railway Postgres. Without it, in-memory stores are used (dev only).
DATABASE_URL=postgres://user:password@host:5432/dbname
# DATABASE_SSL=true        # set when connecting to an external/SSL Postgres
# DATABASE_POOL_MAX=10

# Security (PHASE-2): server-only secrets. HASH_SALT must be set in production
# so abuse-monitoring hashes are stable. Never commit real values.
HASH_SALT=change_me_to_a_long_random_string
# CRON_SECRET=change_me   # PHASE-5: protects /api/jobs/* cron routes

# Rate limit (PHASE-2): conservative defaults; tune before production.
# RATE_LIMIT_MAX=20
# RATE_LIMIT_WINDOW_MS=3600000
# ANALYSIS_LOCK_TTL_MS=180000
